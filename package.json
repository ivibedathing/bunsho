{
  "name": "bunsho",
  "version": "0.0.0",
  "private": true,
  "description": "Open source, self-hosted authoring and control for quality/compliance documents — git inside, Google-Docs outside.",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.29.2",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "pnpm lint && pnpm typecheck && pnpm test",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "verify-audit": "node --env-file-if-exists=.env --import tsx scripts/verify-audit.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.111.0",
    "@prisma/client": "^6.2.1",
    "@tiptap/extension-link": "2.27.2",
    "@tiptap/extension-table": "2.27.2",
    "@tiptap/extension-table-cell": "2.27.2",
    "@tiptap/extension-table-header": "2.27.2",
    "@tiptap/extension-table-row": "2.27.2",
    "@tiptap/pm": "2.27.2",
    "@tiptap/react": "2.27.2",
    "@tiptap/starter-kit": "3.27.4",
    "diff": "^9.0.0",
    "isomorphic-git": "1.38.7",
    "jszip": "3.10.1",
    "lucide-react": "^1.24.0",
    "markdown-it": "14.3.0",
    "motion": "^12.42.2",
    "next": "^15.1.4",
    "next-auth": "5.0.0-beta.31",
    "pg-boss": "12.26.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/diff": "^5.2.3",
    "@types/markdown-it": "14.1.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.0.4",
    "@types/react-dom": "^19.0.2",
    "prisma": "^6.2.1",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.1",
    "typescript": "^5.7.3",
    "vitest": "^4.1.10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma",
      "sharp"
    ],
    "overrides": {
      "postcss@<8.5.10": "^8.5.10"
    }
  }
}

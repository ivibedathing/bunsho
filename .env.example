# Copy to .env for local development: cp .env.example .env
#
# PostgreSQL connection. Matches the docker-compose `db` service defaults.
DATABASE_URL="postgresql://bunsho:bunsho@localhost:5432/bunsho?schema=public"

# Node environment
NODE_ENV="development"

# ── Auth (Auth.js / NextAuth v5) ────────────────────────────────────────────
# Required. Signs session tokens. Generate one with: openssl rand -base64 32
AUTH_SECRET=""

# Organization name used when the first-run admin is created.
ORG_NAME="Bunsho"

# ── Optional SSO via generic OIDC ───────────────────────────────────────────
# Leave blank to disable SSO (credentials-only). Set all three to enable.
OIDC_ISSUER=""
OIDC_CLIENT_ID=""
OIDC_CLIENT_SECRET=""
OIDC_NAME="SSO"

# ── AI assistance (suggestion-only, via the Anthropic API) ──────────────────
# AI features are OFF unless ANTHROPIC_API_KEY is set. Set AI_ENABLED=false to
# force-disable even when a key is present (locked-down deployments).
ANTHROPIC_API_KEY=""
AI_ENABLED="true"
AI_MODEL="claude-opus-4-8"
AI_STALENESS_DAYS="180"          # flag published docs older than this
AI_MAX_SUGGESTIONS_PER_RUN="50"  # cost/rate guard per check run

# Scheduled checks (pg-boss). Off by default; set true + a cron to enable.
AI_SCHEDULED_CHECKS="false"
AI_SCAN_CRON="0 3 * * 1"         # weekly, Monday 03:00 (server time)

# ── Git/Markdown export ─────────────────────────────────────────────────────
# Where "Rebuild git export" writes the one-way git repo (on the data volume).
EXPORT_REPO_PATH=".data/export-repo"
